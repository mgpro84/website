---
import RichText from "../elements/RichText.astro"
import Button from "./utils/Button.astro"

import { storyblokEditable } from "@storyblok/astro"

const { blok } = Astro.props
---

<section
  class="relative min-h-[90vh] flex items-center pt-20 overflow-hidden"
  {...storyblokEditable(blok)}>
  <div class="absolute inset-0 z-0">
    <div
      class="w-full h-full bg-cover bg-center brightness-50"
      data-alt="A professional carpentry workshop with high-end machinery and natural sunlight streaming through large industrial windows, illuminating wood shavings on a polished floor. The atmosphere is clean and precise, with a focus on high-quality wood materials and craftsmanship. The lighting is bright and architectural, reflecting a premium renovation aesthetic with deep navy and cool gray accents."
      style={`background-image: url("${blok.image.filename}");`}>
    </div>
  </div>
  <div
    class="relative z-10 w-full max-w-container-max mx-auto px-margin-desktop text-white">
    <div class="max-w-2xl">
      <span
        class="font-label-caps text-label-caps uppercase tracking-widest text-sky-accent mb-4 block">
        {blok.tagline}
      </span>
      <h1
        class="font-display-lg text-display-lg-mobile md:text-display-lg mb-6 leading-tight">
        {blok.headline}
      </h1>
      <div
        class="font-body-lg text-body-lg mb-10 text-surface-container opacity-90 leading-relaxed">
        <RichText content={blok.subtitle} />
      </div>
      <div class="flex flex-col sm:flex-row gap-gutter">
        {blok.buttons?.map((button) => <Button blok={button} />)}
      </div>
    </div>
  </div>
</section>
