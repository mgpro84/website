---
import RichText from "../elements/RichText.astro"
import { Image } from "astro:assets"

import { storyblokEditable } from "@storyblok/astro"

const { blok } = Astro.props
---

<section
  class="py-section-gap bg-white overflow-hidden zigzag"
  {...storyblokEditable(blok)}>
  <div class="max-w-container-max mx-auto px-margin-desktop">
    <div class="layout flex flex-col items-center gap-16">
      <div class="lg:w-1/2 space-y-6">
        <span
          class="font-label-caps text-sky-accent uppercase tracking-widest block">
          {blok.tagline}
        </span>
        <h2
          class="font-headline-lg text-headline-lg text-deep-navy leading-tight">
          {blok.title}
        </h2>
        {
          blok.content && (
            <div class="space-y-4 text-on-surface-variant font-body-lg prose">
              <RichText content={blok.content} />
            </div>
          )
        }
      </div>
      <div class="lg:w-1/2 relative">
        {
          blok.image?.filename && (
            <div class="relative z-10 rounded-2xl overflow-hidden shadow-2xl border-8 border-surface-container">
              <Image
                src={blok.image.filename}
                alt={blok.image.alt}
                inferSize
                layout="constrained"
                class="w-full h-full object-cover"
              />
            </div>
          )
        }

        <div
          class="absolute -top-6 -right-6 w-32 h-32 bg-sky-accent/10 rounded-full -z-0">
        </div>
        <div
          class="absolute -bottom-6 -left-6 w-24 h-24 bg-caution-gold/20 rounded-lg -z-0">
        </div>
      </div>
    </div>
  </div>
</section>
