---
import RichText from "../elements/RichText.astro"

import { storyblokEditable } from "@storyblok/astro"

const { blok } = Astro.props
---

<section
  class="py-section-gap bg-deep-navy text-white"
  {...storyblokEditable(blok)}>
  <div class="max-w-container-max mx-auto px-margin-desktop text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="font-headline-lg text-headline-lg mb-6">
        {blok.headline}
      </h2>
      <div class="font-body-lg text-body-lg opacity-80 mb-10">
        <RichText content={blok.subtitle} />
      </div>
      <a
        class="inline-block bg-caution-gold text-primary font-button px-10 py-4 rounded-lg hover:scale-105 transition-transform shadow-xl uppercase tracking-wider"
        href={blok.href.url ||
          blok.href.cached_url ||
          blok.href.story.full_slug ||
          "#"}>
        {blok.btnname}
      </a>
    </div>
  </div>
</section>
