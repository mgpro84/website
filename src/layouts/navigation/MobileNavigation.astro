---
// Fundations
import Button from "../../components/elements/Button.astro"
import Wrapper from "../../components/containers/Wrapper.astro"

const { navLinks } = Astro.props
---

<div
  id="mobile-menu"
  class="lg:hidden absolute inset-x-0 top-full overflow-hidden transition-all duration-300 ease-out max-h-0 opacity-0 -translate-y-2 pointer-events-none">
  <div class="pt-2">
    <div class="bg-sky-400 py-8 ring-inset rounded">
      <!-- Navigation Links -->
      <nav class="space-y-3 text-center">
        {
          navLinks.map((link) => (
            <a
              href={link.full_slug}
              class="block text-white text-xl font-medium  focus:text-white  transition">
              {link.name}
            </a>
          ))
        }
      </nav>
    </div>
  </div>
</div>
