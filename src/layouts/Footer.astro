---
import { useStoryblokApi } from "@storyblok/astro"
import Logo from "../components/elements/Logo.astro"
import RichText from "../components/elements/RichText.astro"

const storyblokApi = useStoryblokApi()

let menu, footer, brandtext, rels
try {
  const { data } = await storyblokApi.get(`cdn/stories/global`, {
    version: import.meta.env.IS_PREVIEW ? "draft" : "published",
    token: import.meta.env.STORYBLOK_DELIVERY_API_TOKEN,
    resolve_relations: ["legals", "menu"]
  })
  rels = data.rels
  menu = data.story.content.menu
  footer = data.story.content.legals
  brandtext = data.story.content.footertext
} catch (error) {
  console.error("[DEBUG] Storyblok API error:", error.message)
}
const footerSorted = footer.map((item) => {
  const rel = rels.find((r) => r.uuid === item)
  return {
    name: rel.name,
    full_slug: rel.full_slug === "home" ? "/" : `/${rel.full_slug}`
  }
})
const menuSorted = menu.map((item) => {
  const rel = rels.find((r) => r.uuid === item)
  return {
    name: rel.name,
    full_slug: rel.full_slug === "home" ? "/" : `/${rel.full_slug}`
  }
})
---

<section class="bg-primary py-16">
  <div
    class="mx-auto px-margin-desktop grid grid-cols-1 md:grid-cols-3 gap-12 text-center">
    <div class="text-white">
      <span class="material-symbols-outlined text-4xl text-caution-gold mb-4">
        verified
      </span>
      <h5 class="font-headline-md text-headline-md mb-2">10 ans de garantie</h5>
      <p class="text-white/70">
        Travaux couverts par notre assurance décennale.
      </p>
    </div>
    <div class="text-white">
      <span class="material-symbols-outlined text-4xl text-caution-gold mb-4">
        handyman
      </span>
      <h5 class="font-headline-md text-headline-md mb-2">Expertise locale</h5>
      <p class="text-white/70">
        Une équipe de menuisiers qualifiés et passionnés.
      </p>
    </div>
    <div class="text-white">
      <span class="material-symbols-outlined text-4xl text-caution-gold mb-4">
        thumb_up
      </span>
      <h5 class="font-headline-md text-headline-md mb-2">100% Satisfait</h5>
      <p class="text-white/70">Paiement du solde à la fin des travaux.</p>
    </div>
  </div>
</section>
<footer
  class="w-full py-section-gap px-margin-desktop bg-primary dark:bg-on-primary-fixed text-on-primary dark:text-primary-fixed">
  <div
    class="flex flex-col md:flex-row justify-between items-start gap-gutter mx-auto">
    <div class="max-w-xs">
      <div class="font-headline-md text-headline-md font-bold text-white mb-4">
        <Logo class="w-64 h-auto" />
      </div>
      <div class="opacity-60 text-sm">
        <RichText content={brandtext} />
      </div>
    </div>
    <div class="grid grid-cols-2 gap-12">
      <div>
        <h4 class="font-bold text-caution-gold mb-4">Navigation</h4>
        <ul class="space-y-2">
          {
            menuSorted.map((link) => (
              <li>
                <a
                  class="text-on-primary-container dark:text-outline-variant hover:text-white transition-colors"
                  href={link.full_slug}>
                  {link.name}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
      <div>
        <h4 class="font-bold text-caution-gold mb-4">Informations</h4>
        <ul class="space-y-2">
          {
            footerSorted.map((link) => (
              <li>
                <a
                  class="text-on-primary-container dark:text-outline-variant hover:text-white transition-colors"
                  href={link.full_slug}>
                  {link.name}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
  <div
    class="w-full mt-12 pt-12 border-t border-on-primary-fixed-variant flex flex-col md:flex-row justify-between gap-4 text-sm">
    <p>
      © {new Date().getFullYear()} MG PRO. Tous droits réservés. Fait par <a
        href="https://huitquatre.fr"
        class="text-(--color-caution-gold)">huitquatre.</a
      >
    </p>
  </div>
</footer>
